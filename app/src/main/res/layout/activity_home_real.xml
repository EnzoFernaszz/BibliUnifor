<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeRealActivity">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationView">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Título da Página -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Início"
                android:textSize="38sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- MAIN NEWS CARD (Adaptado) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#99Aaff"
                app:cardCornerRadius="12dp"
                app:contentPadding="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imgLogoUnifor"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/logounifor"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/txtUniforTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unifor"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginStart="8dp"
                        app:layout_constraintTop_toTopOf="@id/imgLogoUnifor"
                        app:layout_constraintStart_toEndOf="@id/imgLogoUnifor" />

                    <TextView
                        android:id="@+id/txtAtividade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atividade Cultural"
                        android:textColor="#333333"
                        android:layout_marginStart="8dp"
                        app:layout_constraintTop_toBottomOf="@id/txtUniforTitle"
                        app:layout_constraintStart_toEndOf="@id/imgLogoUnifor" />

                    <ImageView
                        android:id="@+id/imgMainNews"
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_marginTop="16dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/raquel_de_queiroz_img"
                        app:layout_constraintTop_toBottomOf="@id/imgLogoUnifor"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/txtNewsTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Coleção Rachel de Queiroz"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        app:layout_constraintTop_toBottomOf="@id/imgMainNews"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/txtNewsSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Uma vida em preto e branco"
                        android:textColor="#333333"
                        app:layout_constraintTop_toBottomOf="@id/txtNewsTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/txtNewsDescription"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="A Biblioteca Central da Universidade de Fortaleza (Unifor) abriga grande parte do acervo bibliográfico da escritora cearense Rachel de Queiroz."
                        android:textColor="#333333"
                        app:layout_constraintTop_toBottomOf="@id/txtNewsSubtitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pontinhos Fora do Cartão (Imagem fake para adiantar) -->
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="12dp"
                android:src="@drawable/three_points_backgroundless"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"/>

            <!-- Seção Notificações -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notificações"
                android:layout_marginTop="24dp"
                android:textSize="24sp"
                android:textColor="#000000"
                android:textStyle="bold"/>

            <!-- ITEM DE NOTIFICAÇÃO 1: Enzo / Odisseia -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <!-- Avatar Redondo -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/odisseia_icon" />

                <!-- Textos da Notificação -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enzo Fernandes"
                        android:textSize="12sp"
                        android:textColor="#555555"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Odisseia"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Na Odisseia, Homero estabelece..."
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Tempo e Setinha -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1hr"
                        android:textSize="12sp"
                        android:textColor="#999999"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/seta_direita_backgroundless"

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <!-- Avatar Redondo -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/odisseia_icon" />

                <!-- Textos da Notificação -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enzo Fernandes"
                        android:textSize="12sp"
                        android:textColor="#555555"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Odisseia"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Na Odisseia, Homero estabelece..."
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Tempo e Setinha -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1hr"
                        android:textSize="12sp"
                        android:textColor="#999999"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/seta_direita_backgroundless"

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <!-- Avatar Redondo -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/odisseia_icon" />

                <!-- Textos da Notificação -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enzo Fernandes"
                        android:textSize="12sp"
                        android:textColor="#555555"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Odisseia"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Na Odisseia, Homero estabelece..."
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Tempo e Setinha -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1hr"
                        android:textSize="12sp"
                        android:textColor="#999999"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/seta_direita_backgroundless"

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- FIXED BOTTOM MENU -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="unlabeled"
        app:itemIconTint="@null" />

</androidx.constraintlayout.widget.ConstraintLayout>